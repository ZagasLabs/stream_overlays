{
  "name": "stream-overlays",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Static OBS Browser Source overlays for Social Stream Ninja chat, cooperative words, and alerts.",
  "homepage": "https://zagaslabs.github.io/stream_overlays/",
  "scripts": {
    "dev": "node scripts/dev-server.mjs --app chat",
    "dev:chat": "node scripts/dev-server.mjs --app chat",
    "dev:wordle": "node scripts/dev-server.mjs --app wordlestream",
    "dev:alerts": "node scripts/dev-server.mjs --app alerts",
    "mock": "node scripts/dev-server.mjs --app chat --mock",
    "mock:chat": "node scripts/dev-server.mjs --app chat --mock",
    "mock:wordle": "node scripts/dev-server.mjs --app wordlestream --mock",
    "mock:alerts": "node scripts/dev-server.mjs --app alerts --mock",
    "test": "node --test tests/*.test.mjs wordlestream/tests/*.test.mjs alerts/tests/*.test.mjs",
    "test:chat": "node --test tests/*.test.mjs",
    "test:wordle": "node --test wordlestream/tests/*.test.mjs",
    "test:alerts": "node --test alerts/tests/*.test.mjs",
    "check": "node scripts/check.mjs && npm run test",
    "preflight": "node scripts/preflight.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "url": "node scripts/print-url.mjs --app chat",
    "url:wordle": "node scripts/print-url.mjs --app wordlestream",
    "url:alerts": "node scripts/print-url.mjs --app alerts"
  },
  "engines": {
    "node": ">=24"
  }
}
